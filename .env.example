# =========================================================================
# TalentBloom — Environment Configuration Example
# =========================================================================
# Copy this file to '.env.local' or configure these environment variables
# in your Contentstack Launch deployment dashboard.
# 
# Note: For Next.js client-side compatibility (if used directly on the client),
# use the NEXT_PUBLIC_ prefix. The codebase is designed to support both
# VITE_CS_ and NEXT_PUBLIC_CS_ namespaces, as well as CONTENTSTACK_ prefixes.

# Contentstack API Key for the stack
VITE_CS_API_KEY=your_contentstack_api_key_here
NEXT_PUBLIC_CS_API_KEY=your_contentstack_api_key_here

# Contentstack Delivery Token (Read-only credential for retrieving content)
VITE_CS_DELIVERY_TOKEN=your_contentstack_delivery_token_here
NEXT_PUBLIC_CS_DELIVERY_TOKEN=your_contentstack_delivery_token_here

# Contentstack Environment (e.g., development, staging, production)
VITE_CS_ENV=development
NEXT_PUBLIC_CS_ENV=development

# Optional fallback configurations (Contentstack Launch standard naming)
CONTENTSTACK_API_KEY=your_contentstack_api_key_here
CONTENTSTACK_DELIVERY_TOKEN=your_contentstack_delivery_token_here
CONTENTSTACK_ENVIRONMENT=development

# =========================================================================
# Prisma Database Configuration
# =========================================================================
# Connection string for database (transaction pooler connection)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mercor_clone?schema=public

# Connection string for direct database connection (session pooler connection)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/mercor_clone?schema=public

# =========================================================================
# Supabase Configuration
# =========================================================================
# Public URL of the Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous key for client-side Auth and DB interaction
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Secret service role key for administrative server-side operations (RLS bypass)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# =========================================================================
# AWS S3 Storage Configuration
# =========================================================================
# AWS access key for accessing storage buckets
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here

# AWS secret key matching the access key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here

# AWS Region where the S3 bucket is hosted
AWS_REGION=us-east-1

# Name of the AWS S3 bucket
AWS_BUCKET_NAME=mercor-clone-applications

# Public base URL of the AWS S3 bucket
AWS_BUCKET_URL=https://mercor-clone-applications.s3.amazonaws.com

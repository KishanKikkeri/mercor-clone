# =========================================================================
# TalentBloom — Environment Configuration Example
# =========================================================================
# Copy this file to '.env.local' or configure these environment variables
# in your Contentstack Launch deployment dashboard.
# 
# Note: For Next.js client-side compatibility (if used directly on the client),
# use the NEXT_PUBLIC_ prefix. The codebase is designed to support both
# VITE_CS_ and NEXT_PUBLIC_CS_ namespaces, as well as CONTENTSTACK_ prefixes.

# Contentstack API Key for the stack
VITE_CS_API_KEY=your_contentstack_api_key_here
NEXT_PUBLIC_CS_API_KEY=your_contentstack_api_key_here

# Contentstack Delivery Token (Read-only credential for retrieving content)
VITE_CS_DELIVERY_TOKEN=your_contentstack_delivery_token_here
NEXT_PUBLIC_CS_DELIVERY_TOKEN=your_contentstack_delivery_token_here

# Contentstack Environment (e.g., development, staging, production)
VITE_CS_ENV=development
NEXT_PUBLIC_CS_ENV=development

# Optional fallback configurations (Contentstack Launch standard naming)
CONTENTSTACK_API_KEY=your_contentstack_api_key_here
CONTENTSTACK_DELIVERY_TOKEN=your_contentstack_delivery_token_here
CONTENTSTACK_ENVIRONMENT=development
